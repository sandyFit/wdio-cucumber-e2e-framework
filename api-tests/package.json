  "main": "index.js",
  "scripts": {
    "test:api": "mocha tests/**/*.test.js",
    "test:api:report": "mocha tests/**/*.test.js --reporter spec --reporter mochawesome --reporter-options reportDir=reports/api-reports,reportFilename=api-test-report,html=true,json=false",
    "lint": "eslint tests/**/*.js services/**/*.js schemas/**/*.js",
    "lint:fix": "eslint tests/**/*.js services/**/*.js schemas/**/*.js --fix",
    "format": "prettier --write \"**/*.{js,json}\"",
    "format:check": "prettier --check \"**/*.{js,json}\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.13.2",
    "chai": "^6.2.1",
    "dotenv": "^17.2.3",
    "joi": "^18.0.2",
    "mocha": "^11.7.5"
  },
  "devDependencies": {
    "eslint": "^9.39.2",
    "mochawesome": "^7.1.4",
    "mochawesome-report-generator": "^6.3.2",
    "prettier": "3.7.4"
  }
}
